# ——— الإنتاج (دومين حقيقي) ———
NODE_ENV=production
SITE_URL=https://ark4all.com
SECRET_KEY=
COOKIE_SECURE=true
FORCE_HTTPS=true
BIND_HOST=127.0.0.1
# Hostinger Node.js App: لا تضف BIND_HOST أو HOSTINGER=1 و BIND_HOST=0.0.0.0 — انظر deploy/HOSTINGER.md
PORT=3000
# VERIFY_ORIGIN=1
# فعّله فقط بعد ضبط SITE_URL بدقة (مع www إن لزم)

# قناة يوتيوب
YOUTUBE_CHANNEL_URL=https://www.youtube.com/results?search_query=شفرة+الفطرة

# بريد (تأكيد التسجيل + نسيان كلمة المرور + النشرة)
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=noreply@ark4all.com
SMTP_PASS=
MAIL_FROM="شفرة الفطرة" <noreply@ark4all.com>

# تأكيد البريد: صلاحية الرابط بالدقائق (التفعيل بالضغط فقط — لا تفعيل تلقائي)
EMAIL_VERIFY_TTL_MINUTES=30

# Web Push (اختياري — أو يُولَّد في data/vapid.json)
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
# VAPID_SUBJECT=mailto:admin@yourdomain.com

# ——— مساعدك (اختياري — توليد من مراجع الأرشيف فقط) ———
# LLM_ENABLED=1
# OPENAI_API_KEY=sk-...
# LLM_MODEL=gpt-4o-mini
# OPENAI_BASE_URL=https://api.openai.com/v1
# LLM_MAX_TOKENS=900
# LLM_TIMEOUT_MS=25000

# النشرة التلقائية
# NEWSLETTER_AUTO=1
# NEWSLETTER_INTERVAL_HOURS=24
# NEWSLETTER_CHECK_MINUTES=30

# ——— التطوير المحلي ———
# NODE_ENV=development
# SITE_URL=http://127.0.0.1:3000
# COOKIE_SECURE=false
# FORCE_HTTPS=false
# BIND_HOST=0.0.0.0
